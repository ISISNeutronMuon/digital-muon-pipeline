{
    "events-topics": [ "Events_true", "Events_detector" ],
    "metrics": [
        { "name": "false", "metric-type": "false-count", "true_topic": "Events_true", "estimate_topic": "Events_detector" }
    ],
    "templates": {
        "criteria-templates": [{
            "name": "period-only",
            "frames": {"constant": "any" },
            "channels": {"constant": "any" },
            "digitiser-ids": {"constant": "any" }
        }],
        "bucket-templates": [{
            "name": "by-threshold",
            "number": 1,
            "algorithm": "threshold-only",
            "waveform": "gaussian",
            "limits": { "min": 64, "max": 50000 }
        }],
        "arrays": [
            { "name": "Thresholds", "values": [900] }
        ],
        "algorithms": [{
            "name": "threshold-only",
            "fixed-threshold": {
                "threshold": {"dependant": {"array": "Thresholds" } },
                "duration": {"constant": 1 },
                "cool_down": {"constant": 0 }
            }
        }],
        "waveforms": [{
            "name" : "gaussian",
            "pulse-type": "gaussian",
            "sd": {"constant": 10 }
        }]
    },
    "buckets": [
        {
            "source": "by-threshold",
            "name": "no-noise-low-count-by-theshold",
            "criteria" : {
                "source": "period-only",
                "periods": {"dependant": { "function": { "scale": 6, "value-at-zero": 0} } }
            }
        },
        {
            "source": "by-threshold",
            "name": "low-noise-low-count-by-theshold",
            "criteria" : {
                "source": "period-only",
                "periods": {"dependant": { "function": { "scale": 6, "value-at-zero": 1} } }
            }
        },
        {
            "source": "by-threshold",
            "name": "high-noise-low-count-by-theshold",
            "criteria" : {
                "source": "period-only",
                "periods": {"dependant": { "function": { "scale": 6, "value-at-zero": 2} } }
            }
        },
        {
            "source": "by-threshold",
            "name": "no-noise-high-count-by-theshold",
            "criteria" : {
                "source": "period-only",
                "periods": {"dependant": { "function": { "scale": 6, "value-at-zero": 3} } }
            }
        },
        {
            "source": "by-threshold",
            "name": "low-noise-high-count-by-theshold",
            "criteria" : {
                "source": "period-only",
                "periods": {"dependant": { "function": { "scale": 6, "value-at-zero": 4} } }
            }
        },
        {
            "source": "by-threshold",
            "name": "high-noise-high-count-by-theshold",
            "criteria" : {
                "source": "period-only",
                "periods": {"dependant": { "function": { "scale": 6, "value-at-zero": 5} } }
            }
        }
    ],
    "charts": [
        {
            "width": 1,
            "x-axis": {"dependant": {"array": "Thresholds" } },
            "series": [
                {"metric": "false", "property": "false-positives-mean", "from-bucket": "no-noise-low-count-by-theshold"},
                {"metric": "false", "property": "false-positives-sd",   "from-bucket": "no-noise-low-count-by-theshold"},
                {"metric": "false", "property": "false-negatives-mean", "from-bucket": "no-noise-low-count-by-theshold"},
                {"metric": "false", "property": "false-negatives-sd",   "from-bucket": "no-noise-low-count-by-theshold"}
            ],
            "x-axis-label": "Threshold",
            "title": "No Noise, Low Count"
        }
    ]
}